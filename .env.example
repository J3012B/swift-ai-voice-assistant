# Groq is used to transcribe speech and generate the text response.
# https://console.groq.com/keys
GROQ_API_KEY=

# Cartesia is used to synthesize the text response into speech.
# https://play.cartesia.ai/console
CARTESIA_API_KEY=

OPENAI_API_KEY=

# bot12345...:ABC...
TELEGRAM_ADMIN_BOT_TOKEN=
TELEGRAM_ADMIN_USER_ID=

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

DATABASE_URL=

# Stripe — Monthly subscription paywall
# https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Stripe Price ID for the $19/month subscription
# Find at: https://dashboard.stripe.com/products → click product → copy Price ID (price_xxx)
STRIPE_PRICE_ID=

# Postmark — transactional emails (welcome + quota exceeded)
# https://account.postmarkapp.com/servers → your server → API Tokens
POSTMARK_SERVER_API_TOKEN=
# Must be a verified sender address in Postmark (e.g. josef@talktoyour.computer)
POSTMARK_FROM_EMAIL=
# Sender for transactional/system emails (quota exceeded, etc.)
POSTMARK_NOTIFICATIONS_EMAIL=notifications@talktoyour.computer
# Used in email links (quota exceeded upgrade button)
NEXT_PUBLIC_SITE_URL=https://talktoyourcomputer.com